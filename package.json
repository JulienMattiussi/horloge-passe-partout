{
  "name": "horloge-passe-partout",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n snippet,vite -c magenta,cyan \"npm:build:snippet:watch\" \"vite\"",
    "build": "npm run build:snippet && tsc -b && vite build",
    "preview": "vite preview",
    "build:snippet": "esbuild src/snippet/passe-partout.ts --bundle --outfile=public/passe-partout.js --minify --target=es2019",
    "build:snippet:watch": "esbuild src/snippet/passe-partout.ts --bundle --outfile=public/passe-partout.js --target=es2019 --sourcemap --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
